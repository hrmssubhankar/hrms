# ─────────────────────────────────────────────────────────────────────────────
#  YAHWEH HRMS — Environment Variables Template
#  Copy to .env.local for local development.
#  NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE (Neon PostgreSQL) ─────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# ── AUTHENTICATION ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-secure-random-string-minimum-64-characters-long"
JWT_EXPIRES_IN="8h"

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Default from-address for all outbound emails (must be a verified domain in Resend)
RESEND_FROM="HRMS <noreply@yourdomain.com>"

# ── FILE STORAGE (Vercel Blob) ─────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Create Blob Store → token auto-generated
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── APP URL (server-side only — used in email links + redirects) ───────────
# Production: the public-facing URL of this deployment
# Local dev: http://localhost:3000
APP_URL="http://localhost:3000"

# ── MULTI-TENANT ROUTING ───────────────────────────────────────────────────
# NEXT_PUBLIC_TENANT_SLUG identifies which tenant this deployment serves.
# Required by the login page (client component) to auto-select the correct tenant.
# Set per-deployment in Vercel:
#   superadmin project  →  admin
#   yahwehcare project  →  yahweh-care
#   yahwehpc project    →  yahweh-property-care
NEXT_PUBLIC_TENANT_SLUG="admin"

# ROOT_DOMAIN: only needed for subdomain-based routing (optional / future).
# Example: "yahwehcare.com.au"  →  superadmin.yahwehcare.com.au
# Leave blank when using separate Vercel projects (current default setup).
ROOT_DOMAIN=""
